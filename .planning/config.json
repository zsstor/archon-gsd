  "task_routing": {
    "impl": {
      "models": [
        "gemini-flash",
        "glm-ollama",
        "glm-zai",
        "claude-sonnet"
      ],
      "scoring_mode": "keyword+files",
      "model_constraints": "tier-2-minimum"
    },
    "scaffold": {
      "models": [
        "gemini-flash",
        "glm-ollama"
      ]
    },
    "tdd-cycle": {
      "models": [
        "codex",
        "claude-sonnet"
      ]
    },
    "code-review": {
      "models": [
        "codex",
        "claude-opus"
      ],
      "model_constraints": "cross-family-preferred"
    },
    "complex-refactor": {
      "models": [
        "codex",
        "claude-opus"
      ]
    },
    "judgment": {
      "models": [
        "claude-opus"
      ],
      "model_constraints": "opus-only"
    },
    "trivial": {
      "models": [
        "claude-haiku",
        "gemini-flash"
      ]
    },
    "review": {
      "models": [
        "codex",
        "claude-opus"
      ],
      "scoring_mode": "keyword+files"
    }
  },
  "escalation": {
    "enabled": true,
    "signals": {
      "explicit_failure": true,
      "loop_detection": {
        "enabled": true,
        "threshold": 3
      },
      "test_failure": true,
      "token_exhausted": true
    },
    "chain": {
      "default": [
        "gemini-flash",
        "glm-ollama",
        "glm-zai",
        "codex",
        "claude-sonnet",
        "claude-opus"
      ],
      "code-review": [
        "codex",
        "claude-opus"
      ],
      "judgment": [
        "claude-sonnet",
        "claude-opus"
      ]
    }
  },
  "review": {
    "default_reviewer": "codex",
    "self_review_forbidden": true,
    "post_to_pr": true,
    "finding_routing": {
      "blocking": "escalate_or_remediate",
      "non_blocking_simple": "feed_back",
      "non_blocking_decision": "cleanup_phase"
    }
  },
  "phase_conventions": {
    "cleanup_prefix": "DEBT",
    "backlog_prefix": "PARK",
    "issues_prefix": "WANT",
    "decimal_suffix_start": 1,
    "scope": "milestone"
  },
  "github": {
    "enabled": true,
    "fallback": "local"
  },
  "issues": {
    "triage_label": "autotriaged",
    "query": "-label:autotriaged",
    "auto_models": [
      "claude-haiku",
      "gemini-flash",
      "glm-ollama"
    ]
  },
  "autonomous": {
    "debt_models": [
      "claude-haiku",
      "gemini-flash",
      "glm-ollama"
    ],
    "review_model": "codex",
    "create_draft_pr": true,
    "stop_before_merge": true
  },
  "learning": {
    "enabled": true,
    "log_file": ".planning/delegation-log.jsonl",
    "outcome_fields": [
      "task_type",
      "model",
      "success",
      "escalation_count",
      "tokens_used",
      "duration_ms"
    ]
  },
  "workflow": {
    "_auto_chain_active": false
  },
  "scoring_defaults": {
    "initial_mode": "keyword",
    "upgrade_thresholds": {
      "failure_rate": 0.3,
      "escalation_count": 2
    },
    "complexity_thresholds": {
      "low": 40,
      "high": 70
    },
    "history": {
      "half_life_days": 7,
      "max_age_days": 30,
      "cold_start_prior": 0.5,
      "min_entries_for_confidence": 5
    },
    "keyword_weights": {
      "high": [
        "refactor",
        "migrate",
        "architect",
        "multi-file",
        "complex"
      ],
      "medium": [
        "test",
        "integrate",
        "api",
        "database",
        "auth"
      ]
    }
  },
  "quota_management": {
    "enabled": true,
    "max_wait_seconds": 900,
    "default_backoff_base": 2,
    "default_backoff_max": 300,
    "parse_model": "glm-5.1:cloud",
    "state_dir": "/tmp/quota-state"
  },
  "zarchon_version": "1.0"
}